# ══════════════════════════════════════════════════════════
#   KisanMind — Environment Variables
#   Copy this file to .env and fill in your values.
#   All services marked FREE have no credit card required.
# ══════════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────────────

# Telegram Bot Token (FREE)
# Get from: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key (FREE - no credit card)
# Get from: https://console.groq.com → API Keys
# Free tier: 14,400 requests/day, 30 req/min
GROQ_API_KEY=your_groq_api_key_here

# ── RECOMMENDED (free, enables more features) ───────────────

# Google Gemini API Key (FREE)
# Get from: https://aistudio.google.com/app/apikey
# Enables: Crop disease vision analysis
# Free tier: 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key (FREE)
# Get from: https://openweathermap.org/api → Free plan
# Enables: Weather forecasts, farm alerts
# Free tier: 1000 calls/day
OPENWEATHER_API_KEY=your_openweathermap_key_here

# ── DATABASE (free tier) ────────────────────────────────────

# Supabase (FREE - 500MB storage)
# Get from: https://supabase.com → New Project
# Enables: Persistent farmer profiles across sessions
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── OPTIONAL ────────────────────────────────────────────────

# data.gov.in API Key (FREE with registration)
# Get from: https://data.gov.in → Register → API
# Enables: Live mandi price data from AGMARKNET
DATA_GOV_API_KEY=your_data_gov_key_here

# ── APP SETTINGS ────────────────────────────────────────────

# Debug mode (set to true for development)
DEBUG=false
